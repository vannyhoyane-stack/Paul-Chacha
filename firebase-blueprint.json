{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Gaming products like games, videos, accessories",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 100 },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "videoUrl": { "type": "string" },
        "downloadLink": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["title", "category", "price", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase Request",
      "description": "A user's request to buy a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["productId", "userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store all available products"
    },
    "/purchases/{purchaseId}": {
      "schema": { "$ref": "#/entities/Purchase" },
      "description": "Store user purchase requests for admin to verify"
    }
  }
}
